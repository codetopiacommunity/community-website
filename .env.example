# Database
DATABASE_URL=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Codetopia Community <dispatch@codetopia.org>

# Auth
JWT_SECRET=

# App URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://community.codetopia.org

# SSO — "Continue with Community Portal" (OAuth2 Authorization Code + PKCE)
# PORTAL_WEB_URL: portal frontend base (serves the /authorize consent screen)
# PORTAL_API_URL: portal backend base (serves /o/token/ and /api/v1/oauth/userinfo/)
# OAUTH_* : from `python manage.py seed_oauth_app` on the portal backend
PORTAL_WEB_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_WEB_URL=http://localhost:3000
PORTAL_API_URL=http://localhost:8000
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:3001/api/admin/auth/callback

# Portal API key for server-side user lookups (Wall of Impact / recognitions /
# team). Mint in the portal admin (API keys) scoped to `profile.view` and
# `roles.view` (the latter is needed to list public team-category roles).
PORTAL_API_KEY=
