generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Subscriber {
  id                Int       @id @default(autoincrement())
  email             String    @unique
  name              String?
  status            String    @default("pending")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  tokenExpiresAt    DateTime? @map("token_expires_at")
  verificationToken String?   @unique @map("verification_token")
  verifiedAt        DateTime? @map("verified_at")

  @@map("subscribers")
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("admins")
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  name      String
  role      String
  imageUrl  String?  @map("image_url")
  statement String
  expertise String[]
  tier      String   @default("CORE")
  github    String?
  linkedin  String?
  twitter   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("team_members")
}

model GalleryAlbum {
  id         Int            @id @default(autoincrement())
  slug       String         @unique
  title      String
  date       String
  category   String
  coverImage String         @map("cover_image")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  photos     GalleryPhoto[]

  @@map("gallery_albums")
}

model GalleryPhoto {
  id        Int          @id @default(autoincrement())
  src       String
  alt       String
  albumId   Int          @map("album_id")
  createdAt DateTime     @default(now()) @map("created_at")
  album     GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@map("gallery_photos")
}

model ImpactStory {
  id          Int      @id @default(autoincrement())
  slug        String?  @unique
  title       String
  impact      String
  imageUrl    String   @map("image_url")
  logoUrl     String   @map("logo_url")
  startDate   String   @map("start_date")
  endDate     String?  @map("end_date")
  location    String
  link        String?
  galleryLink String?  @map("gallery_link")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("impact_stories")
}

model ArticlesConfig {
  id            Int      @id @default(autoincrement())
  hashnodeHost  String   @map("hashnode_host")
  featuredSlugs String[] @map("featured_slugs")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("articles_config")
}

model Event {
  id                Int      @id @default(autoincrement())
  slug              String?  @unique
  classification    String
  title             String
  description       String
  startDate         DateTime @map("start_date")
  endDate           DateTime @map("end_date")
  isOnline          Boolean  @default(true) @map("is_online")
  reserveSpotLink   String?  @map("reserve_spot_link")
  joinMeetingLink   String?  @map("join_meeting_link")
  locationUrl       String?  @map("location_url")
  recordedVideoLink String?  @map("recorded_video_link")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("events")
}

model Newsletter {
  id              Int                     @id @default(autoincrement())
  slug            String?  @unique
  subject         String
  previewText     String?                 @map("preview_text")
  markdownContent String                  @map("markdown_content")
  status          String                  @default("draft")
  recipientCount  Int                     @default(0) @map("recipient_count")
  sentAt          DateTime?               @map("sent_at")
  errorMessage    String?                 @map("error_message")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")
  deliveryLogs    NewsletterDeliveryLog[]

  @@map("newsletters")
}

model Spotlight {
  id           Int      @id @default(autoincrement())
  slug         String?  @unique
  name         String
  role         String
  imageUrl     String   @map("image_url")
  contribution String
  links        Json     @default("[]")
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("spotlights")
}

model NewsletterDeliveryLog {
  id              Int        @id @default(autoincrement())
  newsletterId    Int        @map("newsletter_id")
  totalRecipients Int        @map("total_recipients")
  successCount    Int        @map("success_count")
  failCount       Int        @map("fail_count")
  status          String
  completedAt     DateTime   @map("completed_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  newsletter      Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade)

  @@map("newsletter_delivery_logs")
}

model Career {
  id               Int      @id @default(autoincrement())
  slug             String?  @unique
  title            String
  company          String   @default("Codetopia")
  type             String
  location         String
  aboutRole        String   @default("") @map("about_role") @db.Text
  responsibilities String[] @map("responsibilities")
  niceToHave       String[] @map("nice_to_have")
  whatWeOffer      String[] @map("what_we_offer")
  howToApply       String   @default("") @map("how_to_apply") @db.Text
  duration         String?
  requirements     String[]
  link             String?
  expiryDate       DateTime @map("expiry_date")
  isFeatured       Boolean  @default(false) @map("is_featured")
  status           String   @default("open")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("careers")
}
