generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Subscriber {
  id                Int       @id @default(autoincrement())
  email             String    @unique
  name              String?
  status            String    @default("pending")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  tokenExpiresAt    DateTime? @map("token_expires_at")
  verificationToken String?   @unique @map("verification_token")
  verifiedAt        DateTime? @map("verified_at")

  @@map("subscribers")
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("admins")
}

model TeamMember {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  name      String
  role      String
  imageUrl  String?  @map("image_url")
  statement String
  expertise String[]
  tier      String   @default("CORE")
  github    String?
  linkedin  String?
  twitter   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("team_members")
}

model GalleryAlbum {
  id         Int            @id @default(autoincrement())
  slug       String         @unique
  title      String
  date       String
  category   String
  coverImage String         @map("cover_image")
  photos     GalleryPhoto[]
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  @@map("gallery_albums")
}

model GalleryPhoto {
  id        Int          @id @default(autoincrement())
  src       String
  alt       String
  albumId   Int          @map("album_id")
  album     GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now()) @map("created_at")

  @@map("gallery_photos")
}

model Event {
  id                Int      @id @default(autoincrement())
  classification    String
  title             String
  description       String
  startDate         DateTime @map("start_date")
  endDate           DateTime @map("end_date")
  isOnline          Boolean  @default(true) @map("is_online")
  reserveSpotLink   String?  @map("reserve_spot_link")
  joinMeetingLink   String?  @map("join_meeting_link")
  locationUrl       String?  @map("location_url")
  recordedVideoLink String?  @map("recorded_video_link")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("events")
}
